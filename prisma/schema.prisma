// Visitor Management System - District Collector Office, Jalna
// PRODUCTION DATABASE: PostgreSQL (Neon.tech free tier)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// NOTE: Role/VisitorStatus are plain Strings, not native Prisma enums (kept this
// way for compatibility across both the SQLite prototype and Postgres production
// setups). Valid values are enforced in application code
// (see src/lib/masterData.ts and API routes).
// Role:            ADMIN | COLLECTOR | PA | DEPARTMENT_OFFICER
// VisitorStatus:   PENDING | ASSIGNED | IN_PROGRESS | PARTIALLY_RESOLVED | RESOLVED | CLOSED | REJECTED

model Department {
  id           String   @id @default(cuid())
  name         String   @unique
  nameMarathi  String
  code         String   @unique
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  users        User[]
  visitors     Visitor[]
}

model User {
  id                String    @id @default(cuid())
  name              String
  nameMarathi       String?
  email             String    @unique
  mobile            String?
  passwordHash      String
  role              String
  designation       String?
  departmentId      String?
  department        Department?           @relation(fields: [departmentId], references: [id])
  active            Boolean   @default(true)

  resetToken        String?
  resetTokenExpiry  DateTime?

  // Optional TOTP-based 2FA (free - no SMS provider needed). Not yet wired
  // into the login flow; fields exist so this can be turned on without a
  // further schema migration. See SECURITY_AND_OPERATIONS.md.
  totpSecret        String?
  totpEnabled       Boolean   @default(false)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  assignedVisitors  Visitor[]        @relation("AssignedOfficer")
  statusLogs        StatusLog[]
  auditLogs         AuditLog[]
  urgencyReviews    Visitor[]        @relation("UrgencyReviewedBy")
  lettersConfirmed  Visitor[]        @relation("LetterConfirmedBy")
}

model Visitor {
  id                String    @id @default(cuid())
  tokenNo           String    @unique

  name              String
  mobile            String
  address           String
  village           String
  taluka            String
  district          String

  subject           String

  attachmentUrl     String?
  attachmentType    String?

  status            String    @default("PENDING")

  assignedDepartmentId String?
  assignedDepartment   Department? @relation(fields: [assignedDepartmentId], references: [id])

  assignedOfficerId String?
  assignedOfficer   User?    @relation("AssignedOfficer", fields: [assignedOfficerId], references: [id])

  // AI classification results
  aiDepartmentGuess String?
  aiConfidence      Float?
  aiSummary         String?
  aiRawResponse     String?
  aiUrgency         String?
  aiUrgencyReason   String?

  // Human oversight of the AI's urgency flag - addresses "AI decision with no
  // accountability trail": a staff member must actively acknowledge an urgent
  // flag, which is logged (who, when), rather than the flag just sitting there.
  urgencyReviewed    Boolean   @default(false)
  urgencyReviewedById String?
  urgencyReviewedBy   User?    @relation("UrgencyReviewedBy", fields: [urgencyReviewedById], references: [id])
  urgencyReviewedAt   DateTime?

  letterGenerated   Boolean  @default(false)
  letterUrl         String?
  letterGeneratedAt DateTime?
  // Who confirmed/reviewed the case before the letter was generated in their
  // name - addresses "letter auto-signed with no review step".
  letterConfirmedById String?
  letterConfirmedBy   User?  @relation("LetterConfirmedBy", fields: [letterConfirmedById], references: [id])

  meetingWithCollector Boolean @default(true)

  // Data retention: once a record is anonymized (per the retention policy),
  // this is set and the PII fields above are overwritten/redacted. Statistics
  // (status, department, dates) are preserved for continued reporting.
  anonymized         Boolean   @default(false)
  anonymizedAt        DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  statusLogs        StatusLog[]
  auditLogs         AuditLog[]

  @@index([mobile])
  @@index([tokenNo])
  @@index([status])
  @@index([createdAt])
  @@index([aiUrgency])
}

model StatusLog {
  id          String   @id @default(cuid())
  visitorId   String
  visitor     Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  status      String
  remark      String?
  updatedById String?
  updatedBy   User?    @relation(fields: [updatedById], references: [id])
  createdAt   DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  visitorId   String?
  visitor     Visitor? @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  details     String?
  createdAt   DateTime @default(now())
}

model TalukaMaster {
  id       String @id @default(cuid())
  name     String
  district String
  active   Boolean @default(true)

  @@unique([name, district])
}

model DistrictMaster {
  id     String @id @default(cuid())
  name   String @unique
  active Boolean @default(true)
}

model TokenCounter {
  dateKey String @id
  count   Int    @default(0)
}

model DailyBriefing {
  date        String   @id
  content     String
  generatedAt DateTime @default(now())
}

// Zero-cost, self-contained rate limiting (see src/lib/rateLimit.ts) - no
// external service like Upstash/Redis needed. Rows are short-lived and
// cleaned up automatically as buckets are checked.
model RateLimitAttempt {
  id        String   @id @default(cuid())
  bucket    String
  createdAt DateTime @default(now())

  @@index([bucket, createdAt])
}
